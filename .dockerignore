.env.*
!.env.example

# Git
.git
.gitignore

# IDE
.idea
.vscode
*.swp
*.swo

# Documentation
README.md
docs/
*.md

# Tests
__tests__
*.test.*
*.spec.*
coverage
.nyc_output

# OS files
.DS_Store
Thumbs.db

# Development files
docker-compose*.yml
*.local

# Service account keys (SECURITY!)
*.json
!package.json
!package-lock.json
!tsconfig.json
!components.json
