# ─────────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production
.env.production.local
.env*.local

# Service account keys
*.json
!package.json
!package-lock.json
!tsconfig.json
!components.json
service-account*.json
*-credentials.json
*-key.json

# ─────────────────────────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─────────────────────────────────────────────────────────────────────────────────
# Build outputs
# ─────────────────────────────────────────────────────────────────────────────────
.next/
out/
build/
dist/

# ─────────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
data/
prisma/migrations/

# ─────────────────────────────────────────────────────────────────────────────────
# Testing
# ─────────────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output

# ─────────────────────────────────────────────────────────────────────────────────
# IDE & Editors
# ─────────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────────────────────────────────────────
# Temporary files
# ─────────────────────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp
.cache/

# ─────────────────────────────────────────────────────────────────────────────────
# Uploads (local development)
# ─────────────────────────────────────────────────────────────────────────────────
uploads/
public/uploads/

# ─────────────────────────────────────────────────────────────────────────────────
# Vercel
# ─────────────────────────────────────────────────────────────────────────────────
.vercel

# ─────────────────────────────────────────────────────────────────────────────────
