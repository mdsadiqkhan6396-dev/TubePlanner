# ═══════════════════════════════════════════════════════════════════════════════
# TubePlanner - Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY WARNING: Never commit .env or .env.local files to version control!
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# REQUIRED: Application Security
# ─────────────────────────────────────────────────────────────────────────────────

# NextAuth.js Secret - Generate with: openssl rand -base64 32
# This is REQUIRED for production security
AUTH_SECRET=your-auth-secret-generate-with-openssl-rand-base64-32

# Encryption Key for sensitive data - Generate with: openssl rand -hex 32
# Used to encrypt tokens stored in database
ENCRYPTION_KEY=your-64-character-hex-encryption-key-here

# ─────────────────────────────────────────────────────────────────────────────────
# REQUIRED: Google OAuth (YouTube API)
# ─────────────────────────────────────────────────────────────────────────────────
# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# ─────────────────────────────────────────────────────────────────────────────────
# REQUIRED: Google Gemini AI
# ─────────────────────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey

GEMINI_API_KEY=your-gemini-api-key

# ─────────────────────────────────────────────────────────────────────────────────
# REQUIRED: Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────────
# For Google Cloud SQL:
# postgresql://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE
# For development:
# postgresql://postgres:password@localhost:5432/tubeplanner

DATABASE_URL=postgresql://postgres:password@localhost:5432/tubeplanner

# ─────────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Rate Limiting (Upstash Redis)
# ─────────────────────────────────────────────────────────────────────────────────
# Get from: https://console.upstash.com/
# Free tier available - recommended for production

UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─────────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Google Cloud Storage (for video/thumbnail storage)
# ─────────────────────────────────────────────────────────────────────────────────
# Only needed if you want to store files in cloud instead of direct upload

GCS_BUCKET_NAME=your-bucket-name
GCS_PROJECT_ID=your-project-id
# For local dev, set path to service account JSON:
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─────────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Email Notifications
# ─────────────────────────────────────────────────────────────────────────────────
# Get from: https://resend.com/

RESEND_API_KEY=re_xxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────────
# Production Settings
# ─────────────────────────────────────────────────────────────────────────────────

# Application URL (required for OAuth callbacks in production)
NEXTAUTH_URL=http://localhost:3000

# Trust proxy headers (set to true when behind load balancer)
TRUST_PROXY=false

# Enable debug logging (disable in production)
DEBUG=false

# Node environment
NODE_ENV=development
